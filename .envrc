# .envrc — YottaDB development environment
# Loaded automatically by direnv when you cd into ~/projects/ydb/
# Run: direnv allow   (once, after editing)

# Find the YottaDB distribution directory (picks latest installed version)
YDB_DIST=$(ls -d /usr/local/lib/yottadb/r* 2>/dev/null | sort -V | tail -1)

if [[ -z "$YDB_DIST" ]]; then
    echo "WARNING: YottaDB not installed. Run: sudo bash scripts/install-yottadb.sh"
else
    export ydb_dist="$YDB_DIST"

    # Data directory (database files — not in git)
    export ydb_dir="$HOME/data/ydb"
    export ydb_gbldir="$HOME/data/ydb/g/ydb.gld"

    # Routine search path: project routines → test routines → munit (if installed) → ydb stdlib
    MUNIT=""
    [[ -d "$PWD/routines/munit" ]] && MUNIT=" $PWD/routines/munit"
    export ydb_routines="$PWD/routines $PWD/routines/tests${MUNIT} $YDB_DIST"

    # Add ydb to PATH for this shell
    PATH_add "$YDB_DIST"

    # Add project bin/ to PATH so tasks, gtree work without full path
    PATH_add "$PWD/bin"

    echo "YottaDB $YDB_DIST loaded."
fi
