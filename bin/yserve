#!/usr/bin/env bash
# yserve — Start the YottaDB HTTP/JSON server.
# Serves task data (and any other routes in server.m) on localhost.
#
# Usage:
#   yserve           listen on default port 8080
#   yserve 9000      listen on port 9000
#
# Routes:
#   GET /            server info
#   GET /tasks       list all tasks as JSON
#   GET /tasks/:id   get one task as JSON
#
# Examples (from another terminal):
#   curl http://localhost:8080/tasks
#   curl http://localhost:8080/tasks/1

set -euo pipefail

PROJ_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$PROJ_DIR/scripts/ydb-env.sh"

PORT="${1:-8080}"
exec "$YDB" -run %XCMD "do start^server($PORT)"
