#!/usr/bin/env bash
# yrun — Run any YottaDB routine from the terminal.
# Works from any directory.
#
# Usage:
#   yrun ^ROUTINE              run a routine directly
#   yrun ^ROUTINE arg1 arg2    args become $ZCMDLINE inside MUMPS
#
# Examples:
#   yrun ^HELLOTST
#   yrun ^GLOBALTST
#   yrun ^hello

set -euo pipefail

PROJ_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$PROJ_DIR/scripts/ydb-env.sh"

if [[ $# -eq 0 ]]; then
    echo "Usage: yrun ^ROUTINE [args...]"
    echo "       yrun ^HELLOTST"
    echo "       yrun ^hello"
    exit 1
fi

exec "$YDB" -run "$@"
