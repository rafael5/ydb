#!/usr/bin/env bash
# gtree — Visualize a YottaDB global as a tree.
# Works from any directory.
#
# Usage:
#   gtree <globalname>
#   gtree contacts
#   gtree tasks
#   gtree ^tasks           (leading ^ is accepted)

set -euo pipefail

PROJ_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$PROJ_DIR/scripts/ydb-env.sh"

if [[ -z "${1:-}" ]]; then
    echo "Usage: gtree <globalname>"
    echo "       gtree contacts"
    echo "       gtree tasks"
    exit 1
fi

exec "$YDB" -run "^gtreecli" "$1"
