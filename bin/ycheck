#!/usr/bin/env bash
# ycheck — Syntax-check one or all MUMPS routines without running them.
# YottaDB compiles routines to .o on first use; zcompile does it eagerly.
#
# Usage:
#   ycheck hello          check routines/hello.m
#   ycheck tasks          check routines/tasks.m
#   ycheck                check all .m files in routines/
#   ycheck --all          same as above
#
# Exit code: 0 = all OK, 1 = one or more errors.

set -euo pipefail

PROJ_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$PROJ_DIR/scripts/ydb-env.sh"

check_one() {
    local name="$1"
    # Strip .m extension and leading path if provided
    name="${name%.m}"
    name="${name##*/}"

    local file="$PROJ_DIR/routines/${name}.m"
    if [[ ! -f "$file" ]]; then
        file="$PROJ_DIR/routines/tests/${name}.m"
    fi
    if [[ ! -f "$file" ]]; then
        echo "ERROR: $name.m not found in routines/ or routines/tests/" >&2
        return 1
    fi

    echo -n "  $name ... "
    # zcompile compiles and reports errors; exit code non-zero on failure
    if "$YDB" -run %xcmd "zcompile \"$file\"" 2>&1; then
        echo "OK"
    else
        echo "FAIL"
        return 1
    fi
}

errors=0

if [[ "${1:-}" == "--all" ]] || [[ -z "${1:-}" ]]; then
    echo "Checking all routines..."
    for f in "$PROJ_DIR"/routines/*.m "$PROJ_DIR"/routines/tests/*.m; do
        [[ -f "$f" ]] || continue
        check_one "$(basename "$f" .m)" || errors=$((errors+1))
    done
else
    for arg in "$@"; do
        check_one "$arg" || errors=$((errors+1))
    done
fi

echo ""
if [[ $errors -eq 0 ]]; then
    echo "All OK."
else
    echo "$errors file(s) had errors."
    exit 1
fi
