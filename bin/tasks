#!/usr/bin/env bash
# tasks — CLI for the MUMPS task manager.
# Works from any directory.
#
# Usage:
#   tasks add <title>       Add a new task
#   tasks list              List all tasks (open first, then done)
#   tasks done <id>         Mark a task complete
#   tasks undone <id>       Reopen a task
#   tasks del <id>          Delete a task
#   tasks show              Show raw ^tasks global as a tree
#   tasks clear-done        Delete all completed tasks

set -euo pipefail

PROJ_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$PROJ_DIR/scripts/ydb-env.sh"

cmd="${1:-}"
shift 2>/dev/null || true
arg="$*"

# Pass cmd and arg to MUMPS separated by | so multi-word args survive intact.
# Inside MUMPS: cmd=$PIECE($ZCMDLINE,"|",1)  arg=$PIECE($ZCMDLINE,"|",2)
exec "$YDB" -run "^taskscli" "${cmd}|${arg}"
