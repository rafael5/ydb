#!/usr/bin/env bash
# ystate — Snapshot of the YottaDB instance: globals, sizes, recent trace.
# Run this to give Claude (or yourself) a quick picture of current state.
#
# Usage:
#   ystate             full snapshot
#   ystate --globals   globals only
#   ystate --trace     recent trace entries only
#   ystate --trace 50  last 50 trace entries

set -euo pipefail

PROJ_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$PROJ_DIR/scripts/ydb-env.sh"

mode="${1:-}"
trace_n="${2:-20}"

show_globals() {
    echo "── Globals ──────────────────────────────────────────"
    "$YDB" -run globals^ystate 2>/dev/null \
        || echo "  (error listing globals)"
    echo ""
}

show_routines() {
    echo "── Routines ─────────────────────────────────────────"
    local count
    count=$(find "$PROJ_DIR/routines" -name "*.m" ! -path "*/munit/*" | wc -l)
    echo "  $count .m files in routines/"
    echo ""
    find "$PROJ_DIR/routines" -name "*.m" ! -path "*/munit/*" \
        | sort \
        | while read -r f; do
            local name size
            name=$(basename "$f")
            size=$(wc -l < "$f")
            printf "  %-30s %4d lines\n" "$name" "$size"
        done
    echo ""
}

show_trace() {
    echo "── Recent trace (last ${trace_n} entries) ────────────────"
    "$YDB" -run trace^ystate "${trace_n}" 2>/dev/null \
        || echo "  (no trace entries)"
    echo ""
}

show_test_status() {
    echo "── Last test run ─────────────────────────────────────"
    if [[ -f "$PROJ_DIR/.last-test-output" ]]; then
        tail -5 "$PROJ_DIR/.last-test-output"
    else
        echo "  (run 'make test' first)"
    fi
    echo ""
}

echo ""
echo "YottaDB State — $(date '+%Y-%m-%d %H:%M:%S')"
echo "  Instance: $ydb_gbldir"
echo "  Routines: $PROJ_DIR/routines/"
echo ""

case "$mode" in
    --globals)  show_globals ;;
    --trace)    show_trace ;;
    --routines) show_routines ;;
    *)
        show_globals
        show_routines
        show_trace
        ;;
esac
