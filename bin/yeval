#!/usr/bin/env bash
# yeval — Evaluate a MUMPS expression or command from the shell.
# The single most useful debugging tool: inspect any value without
# opening an interactive session.
#
# Usage:
#   yeval 'write $$greet^hello("World")'     no ! needed — shell adds newline
#   yeval 'write $get(^tasks(1))'
#   yeval 'do list^tasks()'
#   yeval 'write $$count^tasks()'
#   yeval 'do show^gtree("tasks")'
#
# IMPORTANT: do NOT use ! (newline) in expressions — YDB's CLI parser
# treats ! specially. Omit it; the shell prompt provides the newline.
#
# Tip — add a shell alias for fast use:
#   alias m='yeval'
#   m 'write $get(^tasks(1))'

set -euo pipefail

PROJ_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$PROJ_DIR/scripts/ydb-env.sh"

if [[ -z "${1:-}" ]]; then
    echo "Usage: yeval '<mumps code>'"
    echo "       yeval 'write \$\$greet^hello(\"World\"),!'"
    echo "       yeval 'do list^tasks()'"
    exit 1
fi

# %XCMD XECUTEs the argument and exits — no need to append halt.
exec "$YDB" -run %XCMD "$1"
